<Window x:Class="Knode.CorpusHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Getting started — corpus.jsonl"
        Height="620" Width="680"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F5">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Padding="14,8" MinWidth="100" IsDefault="True" Click="Close_Click"
                    Style="{StaticResource AccentButton}"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="560">
                <TextBlock Text="Create or locate corpus.jsonl" FontSize="22" FontWeight="SemiBold" Foreground="#1a1a1e" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#5c5c66" FontSize="13" LineHeight="20"
                           Text="Knode searches your Kindle highlights from a JSONL file (one JSON object per line). You can point to an existing file or build one with the Python pipeline in this repo."/>

                <Border Style="{StaticResource CardBorder}" Margin="0,18,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Option A — You already have corpus.jsonl" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20"
                                   Text="Click Browse on the main window and select your file. The path is remembered for next time."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Option B — Create it from Kindle Notebook (recommended checks)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20" Margin="0,0,0,10"
                                   Text="The repo pipeline turns Notebook text into structured JSONL and validates metadata before you index in Knode. Each step has a defined role (capture → dedupe → parse → validate)."/>

                        <TextBlock Text="1. WebView capture" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20" Margin="0,0,0,8"
                                   Text="Run spike/webview-notebook (pywebview): sign in, open each book, press Enter to append captures to spike_extract.txt. Details: spike/webview-notebook/README.md."/>

                        <TextBlock Text="2. Dedupe raw captures (optional but recommended)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20" Margin="0,0,0,4"
                                   Text="If you captured the same book twice, run dedupe_spike_extract.py in that spike folder → spike_extract_deduped.txt (+ dedupe_report.txt)."/>
                        <Border Background="#1e1e24" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#e8e8ed" TextWrapping="Wrap"
                                       Text=".\.venv\Scripts\python.exe dedupe_spike_extract.py"/>
                        </Border>

                        <TextBlock Text="3. Parse to corpus.jsonl" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20" Margin="0,0,0,4"
                                   Text="parse_dump reads YOUR KINDLE NOTES FOR: sections, highlights (Location/Page), Last accessed, notes → one JSON object per line. It also drops duplicate ids when the same highlight appears in multiple sections."/>
                        <Border Background="#1e1e24" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#e8e8ed" TextWrapping="Wrap"
                                       Text="cd mvp&#x0a;.\.venv\Scripts\python.exe -m kindle_agent.parse_dump&#x0a;.\.venv\Scripts\python.exe -m kindle_agent.validate_corpus"/>
                        </Border>

                        <TextBlock Text="4. validate_corpus (do this before Knode)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20" Margin="0,0,0,10"
                                   Text="Exits 0 only if every row has a non-empty book_title (and reports empty author rows). Fix the export or parser if it fails — Knode will still index lines with text, but book scoping and citations need titles."/>

                        <TextBlock Margin="0,0,0,0" TextWrapping="Wrap" FontSize="12" Foreground="#6b6b76">
                            Full venv setup: mvp/README.md · Architecture: docs/KNODE-MVP-GUIDE.md §4.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Then in Knode" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#42424a" FontSize="13" LineHeight="20"
                                   Text="Choose the file → enter your AI agent API key (this MVP uses Google Gemini) → Build index → Ask."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
