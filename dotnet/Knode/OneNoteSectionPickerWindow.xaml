<Window x:Class="Knode.OneNoteSectionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select OneNote sections"
        Height="600" Width="760"
        MinHeight="460" MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose OneNote sections to include in retrieval" FontSize="18" FontWeight="SemiBold" Foreground="#111827"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12.5" Foreground="#64748B" Margin="0,6,0,10"
                   Text="Selections are page-level: each page becomes one vector record. Use Ctrl/Shift for multi-select, or Select all / Clear selection."/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Select all" Padding="10,6" Style="{StaticResource SecondaryButton}" Click="SelectAll_Click"/>
            <Button Content="Clear selection" Padding="10,6" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="ClearSelection_Click"/>
        </StackPanel>

        <ListBox x:Name="SectionsList" Grid.Row="3"
                 SelectionMode="Extended"
                 BorderBrush="#D1D5DB"
                 BorderThickness="1"
                 Background="White"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="6,4">
                        <TextBlock Text="{Binding Label}" TextWrapping="Wrap" Foreground="#1F2937"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="SelectionHintText" Grid.Row="4" Margin="0,10,0,0" FontSize="12" Foreground="#475569"
                   Text="No sections selected."/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="12,8" Margin="0,0,8,0" Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
            <Button Content="Use selected" Padding="14,8" MinWidth="120" Style="{StaticResource AccentButton}" IsDefault="True" Click="UseSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>
